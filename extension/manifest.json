{
  "manifest_version": 3,
  "name": "InstaSentry",
  "version": "1.0.2",
  "description": "Behavioral analysis tool for detecting patterns of automated and coordinated account activity on Instagram.",

  "icons": {
    "16": "icons/16x16.png",
    "32": "icons/32x32.png",
    "48": "icons/48x48.png",
    "64": "icons/64x64.png",
    "128": "icons/128x128.png",
    "256": "icons/256x256.png",
    "512": "icons/512x512.png"
  },

  "action": {
    "default_title": "InstaSentry",
    "default_icon": {
      "16": "icons/16x16.png",
      "32": "icons/32x32.png",
      "48": "icons/48x48.png"
    }
  },

  "permissions": ["sidePanel", "downloads"],
  "host_permissions": ["http://127.0.0.1:5000/*"],

  "background": {
    "service_worker": "background.js"
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  }
}